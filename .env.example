# Example environment variables. Copy this to `.env` and fill secrets locally.

# Database (local dev)
POSTGRES_PASSWORD=password
USER_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db1:5432/userdb
PRODUCT_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db2:5433/productdb
ORDER_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db3:5434/orderdb
NOTIFICATION_DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db4:5435/notificationdb

# JWT
JWT_SECRET=change_me_to_a_strong_secret

# Oracle Cloud / OCIR (used by CI/CD and deployment)
# Note: For CI, these should be configured as GitHub Secrets, not stored in this file.
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_TENANCY_OCID=
OCI_REGION=us-phoenix-1
OCI_NAMESPACE=
OCIR_REGISTRY=phx.ocir.io/your-namespace
OCIR_AUTH_TOKEN=

# Deployment (SSH-based deploy to Always Free host)
DEPLOY_SSH_USER=opc
DEPLOY_HOST=

# Optional integrations
SLACK_WEBHOOK=
